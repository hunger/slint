{
    "name": "slint",
    "scopeName": "source.slint",
    "patterns": [
        {
            "include": "#comment"
        },
        {
            "include": "#import-list"
        },
        {
            "include": "#export-list"
        },
        {
            "include": "#struct"
        },
        {
            "include": "#component"
        },
        {
            "include": "#global"
        },
        {
            "match": "(?<!-)\\bexport\\b(?!-)",
            "name": "keyword.other"
        }
    ],
    "repository": {
        "block-comment": {
            "patterns": [
                {
                    "contentName": "comment.block",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "include": "#block-comment"
                        }
                    ]
                }
            ]
        },
        "line-comment": {
            "patterns": [
                {
                    "match": "//.*$",
                    "name": "comment.line.double-slash"
                }
            ]
        },
        "comment": {
            "patterns": [
                {
                    "include": "#block-comment"
                },
                {
                    "include": "#line-comment"
                }
            ]
        },
        "identifier-name": {
            "patterns": [
                {
                    "match": "(?<!-)([a-zA-Z_][a-zA-Z0-9_-]*)(?!-)",
                    "captures": {
                        "2": {
                            "name": "variable.other"
                        }
                    }
                }
            ]
            
        },
        "type-name": {
            "patterns": [
                {
                    "match": "(?<!-)([a-zA-Z_][a-zA-Z0-9_-]*)(?!-)",
                    "captures": {
                        "2": {
                            "name": "storage.type"
                        }
                    }
                }
            ]
        },
        "import-list": {
            "patterns": [
                {
                    "begin": "(?<!-)\\b(import)\\s*\\{",
                    "end": "\\}\\s*(from)\\s*(\"[^\"]*\")\\s*;",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other"
                        }
                    },
                    "endCaptures": {
                        "1": {
                            "name": "keyword.other"
                        },
                        "2": {
                            "name": "string.quoted.double"
                        }
                    },
                    "patterns": [
                        {
                            "match": "\\bas\\b",
                            "name": "keyword.other"
                        },
                        {
                            "match": "[a-zA-Z_][a-zA-Z0-9_-]*",
                            "name": "storage.type"
                        },
                        {
                            "include": "#comment"
                        }
                    ]
                }
            ]
        },
        "export-list": {
            "patterns": [
                {
                    "begin": "(?<!-)\\b(export)\\s*\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other"
                        }
                    },
                    "patterns": [
                        {
                            "match": "\\bas\\b",
                            "name": "keyword.other"
                        },
                        {
                            "match": "[a-zA-Z_][a-zA-Z0-9_-]*",
                            "name": "storage.type"
                        },
                        {
                            "include": "#comment"
                        }
                    ]
                }
            ]
        },
        "struct": {
            "patterns": [
                {
                    "begin": "(?<!-)\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\{",
                    "end": "\\}",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other"
                        },
                        "2": {
                            "name": "storage.type"
                        }
                    },
                    "patterns": [
                        {
                            "match": "([a-zA-Z_][a-zA-Z0-9_-]*)\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_-]*)\\s*,?",
                            "captures": {
                                "1": {
                                    "name": "variable.parameter"
                                },
                                "2": {
                                    "name": "storage.type"
                                }
                            }
                        },
                        {
                            "include": "#comment"
                        }
                    ]
                }
            ]
        },
        "component": {
            "patterns": [
                {
                    "match": "(?<!-)\\b(component)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)(?=\\s*[^\\{])",
                    "captures": {
                        "1": {
                            "name": "keyword.other"
                        },
                        "2": {
                            "name": "storage.type"
                        }
                    }
                },
                {
                    "begin": "(?<!-)\\b(component|inherits)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)(?=\\s*\\{)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other"
                        },
                        "2": {
                            "name": "storage.type"
                        }
                    },
                    "end": "\\}",
                    "patterns": [
                        {
                            "include": "#component-contents"
                        }
                    ]
                }
            ]
        },
        "global": {
            "patterns": [
                {
                    "begin": "(?<!-)\\b(global)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\{",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other"
                        },
                        "2": {
                            "name": "storage.type"
                        }
                    },
                    "end": "\\}",
                    "patterns": [
                        {
                            "include": "#component-contents"
                        }
                    ]
                }
            ]
        },
        "component-contents": {
            "patterns": [
                {
                    "include": "#comment"
                },
                {
                    "include": "#function"
                },
                {
                    "include": "#property"
                },
                {
                    "include": "#code-block"
                },
                {
                    "include": "#value"
                },
                {
                    "match": "(?<!-)\\b(animate|states|transitions|private|public|pure|in|out|in-out|changed)\\b(?!-)",
                    "name": "keyword.other"
                }
            ]
        },
        "property": {
            "patterns": [
                {
                    "begin": "\\b(property)\\b",
                    "end": "(;|:|<=>)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other"
                        }
                    },
                    "patterns": [
                        {
                            "match": "<([a-zA-Z_][a-zA-Z0-9_-]*)>",
                            "captures": {
                                "1": {
                                    "name": "storage.type"
                                }
                            }
                        },
                        {
                            "match": "[a-zA-Z_][a-zA-Z0-9_-]*",
                            "name": "variable.parameter"
                        },
                        {
                            "match": "\\b(<=>|:)\\b",
                            "name": "keyword.operator"
                        }
                    ]
                },
                {
                    "begin": "(:|<=>)",
                    "end": ";",
                    "patterns": [
                        {
                            "include": "#code-block-contents"
                        }
                    ]
                }
            ]
        },
        "code-block": {
            "patterns": [
                {
                    "begin": "\b=>\\s*\\{\\b",
                    "end": "\\}",
                    "patterns": [
                        {
                            "include": "#code-block-contents"
                        }
                    ]
                }
            ]
        },
        "code-block-contents": {
            "patterns": [
                {
                    "include": "#comment"
                },
                {
                    "include": "#value"
                },
                {
                    "match": "(for|if|return)",
                    "name": "keyword.control"
                }
            ]
        },
        "string": {
            "patterns": [
                {
                    "name": "string.quoted.double",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.untitled",
                            "match": "\\\\(n|\\\\|u\\{\\d+\\}|\\{[^\\}]+\\})"
                        }
                    ]
                }
            ]
        },
        "color": {
            "patterns": [
                {
                    "match": "#([a-fA-F0-9]){3,8}",
                    "name": "constant.other"
                },
                {
                    "match": "\\b((Colors)\\.)(aliceblue|antiquewhite|aqua|aquamarine|azure|beige|bisque|black|blanchedalmond|blue|blueviolet|brown|burlywood|cadetblue|chartreuse|chocolate|coral|cornflowerblue|cornsilk|crimson|cyan|darkblue|darkcyan|darkgoldenrod|darkgray|darkgreen|darkgrey|darkkhaki|darkmagenta|darkolivegreen|darkorange|darkorchid|darkred|darksalmon|darkseagreen|darkslateblue|darkslategray|darkslategrey|darkturquoise|darkviolet|deeppink|deepskyblue|dimgray|dimgrey|dodgerblue|firebrick|floralwhite|forestgreen|fuchsia|gainsboro|ghostwhite|gold|goldenrod|gray|green|greenyellow|grey|honeydew|hotpink|indianred|indigo|ivory|khaki|lavender|lavenderblush|lawngreen|lemonchiffon|lightblue|lightcoral|lightcyan|lightgoldenrodyellow|lightgray|lightgreen|lightgrey|lightpink|lightsalmon|lightseagreen|lightskyblue|lightslategray|lightslategrey|lightsteelblue|lightyellow|lime|limegreen|linen|magenta|maroon|mediumaquamarine|mediumblue|mediumorchid|mediumpurple|mediumseagreen|mediumslateblue|mediumspringgreen|mediumturquoise|mediumvioletred|midnightblue|mintcream|mistyrose|moccasin|navajowhite|navy|oldlace|olive|olivedrab|orange|orangered|orchid|palegoldenrod|palegreen|paleturquoise|palevioletred|papayawhip|peachpuff|peru|pink|plum|powderblue|purple|rebeccapurple|red|rosybrown|royalblue|saddlebrown|salmon|sandybrown|seagreen|seashell|sienna|silver|skyblue|slateblue|slategray|slategrey|snow|springgreen|steelblue|tan|teal|thistle|tomato|transparent|turquoise|violet|wheat|white|whitesmoke|yellow|yellowgreen)\\b",
                    "captures": {
                        "2": {
                            "name": "support.class"
                        },
                        "3": {
                            "name": "support.constant"
                        }
                    }
                }
            ]
        },
        "boolean": {
            "patterns": [
                {
                    "match": "\\b(true|false)\\b",
                    "name": "constant.language"
                }
            ]
        },
        "number": {
            "patterns": [
                {
                    "match": "(\\+|-)?\\d+(\\.\\d*)?(%|px|phx|pt|in|mm|cm|ms|s|deg|rad|rem|turn)?",
                    "name": "constant.numeric"
                }
            ]
        },
        "language-variables": {
            "patterns": [
                {
                    "match": "\\b(root|parent|this|self)\\b",
                    "name": "variable.language"
                }
            ]
        },
        "value": {
            "patterns": [
                {
                    "include": "#string"
                },
                {
                    "include": "#color"
                },
                {
                    "include": "#number"
                },
                {
                    "include": "#boolean"
                },
                {
                    "include": "#language-variables"
                },
                {
                    "match": "@(tr|linear-gradient|radial-gradient|image-url)\\*\\(",
                    "captures": {
                        "1": {
                            "name": "support.function"
                        }
                    }
                },
                {
                    "begin": "(?<!-)([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\(",
                    "beginCaptures": {
                        "1": {
                            "name": "entity.name.function"
                        }
                    },
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#value"
                        }
                    ]
                },
                {
                    "match": "[a-zA-Z_][a-zA-Z0-9_-]*",
                    "name": "variable.other"
                }
            ]
        },
        "function": {
            "patterns": [
                {
                    "begin": "(?<!-)(function|callback)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\(",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other"
                        },
                        "2": {
                            "name": "entity.name.function"
                        }
                    },
                    "end": "\\)(\\s*->\\s*([a-zA-Z_][a-zA-Z0-9_-]*))",
                    "endCaptures": {
                        "2": {
                            "name": "storage.type"
                        }
                    },
                    "patterns": [
                        {
                            "match": "(?<!-)(([a-zA-Z_][a-zA-Z0-9_-]*)\\s*:\\s*)?([a-zA-Z_][a-zA-Z0-9_-]*)\\b(?!-)",
                            "captures": {
                                "3": {
                                    "name": "variable.parameter"
                                },
                                "4": {
                                    "name": "storage.type"
                                }
                            }
                        }
                    ]
                }
            ]
        }
    }
}
